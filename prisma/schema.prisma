generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  Pending
  Processing
  Completed
  Failed
  NeedAuth
}

model User {
  id            String   @id
  username      String   @unique
  email         String?  @unique
  passwordHash  String
  platform      String   @default("netease")
  cookie        String?
  lastLoginTime DateTime
  isApproved    Boolean  @default(false)
  tasks         Task[]
  verificationTokens VerificationToken[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Task {
  id                  String     @id
  ownerId             String
  status              TaskStatus
  progress            Int
  resultUrl           String?
  errorMessage        String?
  configJson          String
  actualTotalDuration Int?
  distributionJson    String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  owner               User       @relation(fields: [ownerId], references: [id])
}

model VerificationToken {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}